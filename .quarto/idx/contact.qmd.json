{"title":"Contact","markdown":{"yaml":{"title":"Contact"},"containsRefs":false,"markdown":"\n\n```{=html}\n<!-- Contact Hero -->\n<div class=\"contact-section\" style=\"margin-top: -56px; padding-top: 56px;\">\n  <div class=\"container\">\n    <div class=\"section-title-wrapper\">\n      <span class=\"section-badge\" style=\"border: 1px solid rgba(255,255,255,0.2); color: var(--color-gold-light); background: rgba(255,255,255,0.05);\">Contact Us</span>\n      <h2 style=\"color: #ffffff !important;\">Get in Touch</h2>\n      <div class=\"gold-line\"></div>\n      <p style=\"color: rgba(255,255,255,0.7); max-width: 600px; margin: 0 auto; font-size: 1.05rem; line-height: 1.8;\">\n        Interested in collaborating, joining our lab, or learning more about\n        our research? We would love to hear from you.\n      </p>\n    </div>\n\n    <div class=\"row g-4 justify-content-center\" style=\"max-width: 900px; margin: 0 auto;\">\n      <!-- Email -->\n      <div class=\"col-md-4\">\n        <div class=\"contact-card\">\n          <div class=\"contact-icon\"><img src=\"images/contact.png\" alt=\"Email\" style=\"width: 56px; height: 56px; object-fit: contain;\"></div>\n          <div class=\"contact-title\">Email</div>\n          <div class=\"contact-text\">\n            <a href=\"mailto:risklab@wits.ac.za\" class=\"contact-link\">\n              risklab@wits.ac.za\n            </a>\n          </div>\n        </div>\n      </div>\n\n      <!-- Location -->\n      <div class=\"col-md-4\">\n        <div class=\"contact-card\">\n          <div class=\"contact-icon\"><img src=\"images/location.png\" alt=\"Location\" style=\"width: 56px; height: 56px; object-fit: contain;\"></div>\n          <div class=\"contact-title\">Location</div>\n          <div class=\"contact-text\">\n            School of Statistics & Actuarial Science<br />\n            University of the Witwatersrand<br />\n            Johannesburg, South Africa\n          </div>\n        </div>\n      </div>\n\n      <!-- Connect -->\n      <div class=\"col-md-4\">\n        <div class=\"contact-card\">\n          <div class=\"contact-icon\"><img src=\"images/connect.png\" alt=\"Connect\" style=\"width: 56px; height: 56px; object-fit: contain;\"></div>\n          <div class=\"contact-title\">Connect</div>\n          <div class=\"contact-text\">\n            Follow us on LinkedIn for the latest\n            updates on our research and activities.\n            <br /><br />\n            <a href=\"#\" class=\"contact-link\">\n              Visit LinkedIn →\n            </a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- Additional Info -->\n<div style=\"padding: 5rem 0; background: white;\">\n  <div class=\"container\">\n    <div class=\"section-title-wrapper\">\n      <span class=\"section-badge badge-navy\">Information</span>\n      <h2>Useful Links</h2>\n      <div class=\"gold-line\"></div>\n    </div>\n\n    <div class=\"row g-4 justify-content-center\" style=\"max-width: 800px; margin: 0 auto;\">\n      <div class=\"col-md-4\">\n        <div class=\"partner-card\">\n          <img src=\"images/wits.jpg\" alt=\"WITS\" style=\"width: 56px; height: 56px; object-fit: contain; border-radius: 12px; margin-bottom: 0.5rem;\">\n          <div class=\"partner-name\">WITS University</div>\n          <div class=\"partner-text\">\n            Official website of the University of the Witwatersrand.\n          </div>\n          <a href=\"https://www.wits.ac.za\" target=\"_blank\" class=\"contact-link\" style=\"margin-top: 1rem; display: inline-block;\">\n            Visit →\n          </a>\n        </div>\n      </div>\n      <div class=\"col-md-4\">\n        <div class=\"partner-card\">\n           <img src=\"images/oldmutual.jpg\" alt=\"Old Mutual Insure\" style=\"width: 56px; height: 56px; object-fit: contain; border-radius: 12px; margin-bottom: 0.5rem;\">\n          <div class=\"partner-name\">Old Mutual South Africa</div>\n          <div class=\"partner-text\">\n            Learn more about Old Mutual's insurance and financial services.\n          </div>\n          <a href=\"https://www.oldmutual.co.za\" target=\"_blank\" class=\"contact-link\" style=\"margin-top: 1rem; display: inline-block;\">\n            Visit →\n          </a>\n        </div>\n      </div>\n      <div class=\"col-md-4\">\n        <div class=\"partner-card\">\n          <img src=\"images/rail.png\" alt=\"RAIL Lab\" style=\"width: 56px; height: 56px; object-fit: contain; border-radius: 12px; margin-bottom: 0.5rem;\">\n          <div class=\"partner-name\">RAIL Lab (WITS)</div>\n          <div class=\"partner-text\">\n            The Robotics, AI & Learning Lab — a sister lab at WITS.\n          </div>\n          <a href=\"https://www.raillab.org\" target=\"_blank\" class=\"contact-link\" style=\"margin-top: 1rem; display: inline-block;\">\n            Visit →\n          </a>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- Map placeholder -->\n<div class=\"bg-light-section\" style=\"padding: 4rem 0;\">\n  <div class=\"container\">\n    <div class=\"text-center\">\n      <h3 style=\"color: var(--color-navy) !important; margin-bottom: 1rem;\">\n        Find Us on Campus\n      </h3>\n      <p style=\"color: #666; max-width: 600px; margin: 0 auto 1.5rem; font-size: 0.95rem;\">\n        The Risk Lab is located in the School of Statistics and Actuarial Science,\n        West Campus, University of the Witwatersrand, Johannesburg.\n      </p>\n      <iframe\n        src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3579.7!2d28.03!3d-26.19!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1e950f00%3A0x0!2sUniversity+of+the+Witwatersrand!5e0!3m2!1sen!2sza!4v1600000000000!5m2!1sen!2sza\"\n        width=\"100%\"\n        height=\"350\"\n        style=\"border:0; border-radius: 12px; max-width: 800px; margin: 0 auto; display: block; box-shadow: 0 4px 15px rgba(0,0,0,0.1);\"\n        allowfullscreen=\"\"\n        loadin